generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// =====================================================
// CANONICAL TEMPLATES (GLOBAL)
// =====================================================

model Template {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  name               String
  slug               String    @unique
  type               String

  placeholderSchema   Json?
  contentJsonTemplate Json?
  supportedPresets    String[] @default(["corporate"])

  aiConfig            Json?    // 👈 ADD THIS LINE

  documents          Document[]
}

// =====================================================
// DOCUMENTS (WORKSPACE OWNED)
// =====================================================

model Document {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  title       String

  templateId  String
  template    Template @relation(fields: [templateId], references: [id])

  // v0: document-owned data
  brand       Json?
  variables   Json?     // already exists (keep)
  contentJson Json?
}

